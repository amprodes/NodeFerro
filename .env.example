# Frontend
# Leave empty in Vercel (same-origin /api). For local Vite against deployed API use: https://your-domain.vercel.app
VITE_API_URL=

# Backend / API
# Use ONE of these for Postgr                                                                           
DATABASE_URL=
SUPABASE_DB_URL=

# Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=
# Stripe Dashboard -> Developers -> Webhooks -> endpoint signing secret
STRIPE_WEBHOOK_SECRET=

# Resend Dashboard -> API Keys
RESEND_API_KEY=
# Verified sender identity in Resend
ORDER_FROM_EMAIL=

# Stripe Dashboard -> Developers -> API keys -> Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=